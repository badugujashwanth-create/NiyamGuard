FROM node:22-slim

WORKDIR /app

ARG VITE_API_BASE_URL=http://127.0.0.1:8000
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_APP_NAME="NiyamGuard AI"

COPY frontend/package*.json /app/
RUN npm ci

COPY frontend/ /app/
RUN npm run build

EXPOSE 5173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5173"]
