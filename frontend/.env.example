VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_APP_NAME=NiyamGuard AI
VITE_DEMO_SPEECH_SAFE_MODE=true
# Stop backend recordings after this maximum duration; silence detection normally
# stops earlier after the citizen finishes speaking.
VITE_STT_RECORDING_MS=5500
# Browser te-IN recognition is preferred because small CPU Whisper models can
# produce cross-script Telugu output. Set false to force backend STT first.
VITE_PREFER_BROWSER_STT_FOR_TELUGU=true
