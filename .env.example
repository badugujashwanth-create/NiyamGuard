APP_NAME=NiyamGuard AI
APP_ENV=development
DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/niyamguard
SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUSTED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
DEMO_MODE=true
SEED_DEMO_ON_STARTUP=false
AI_PROVIDER=ollama
AI_ENABLED=true
ANSWER_ENGINE=hybrid_intelligence
SEARCH_ENGINE_ENABLED=true
BM25_ENABLED=true
SEMANTIC_SEARCH_ENABLED=true
ANSWER_TEMPLATES_ENABLED=true
EMBEDDING_MODEL=intfloat/multilingual-e5-small
VECTOR_STORE=local
VECTOR_INDEX_PATH=./data/vector_index
SEARCH_INDEX_PATH=./data/search_index
SEARCH_TOP_K=5
SEARCH_MIN_SCORE=0.25
LLM_OPTIONAL=true
LLM_REQUIRED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_FALLBACK_MODEL=llama3.2:3b
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2
AI_REQUIRE_SOURCES=true
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.25
RAG_INDEX_PATH=./data/rag_index
DATASET_DIR=./data/datasets
DATASET_PACK_DIR=./data/niyamguard_dataset_pack_v1
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL_MINUTES=60
AUTO_APPROVE_DEMO_UPDATES=false
AUTO_PATCH_DEMO_SYSTEMS=false
CIRCULAR_SOURCE_MODE=manual
CIRCULAR_SOURCE_REGISTRY_PATH=./data/source_registry.json
POLICY_UPDATE_REQUIRES_APPROVAL=true
POLICY_ROLLBACK_ENABLED=true
RAG_REINDEX_ON_POLICY_UPDATE=true
COMPLIANCE_RERUN_ON_POLICY_UPDATE=true
LOG_LEVEL=INFO

# Frontend demo setting
VITE_DEMO_SPEECH_SAFE_MODE=true
