    {
      "key": "declaration",
      "label": "I confirm there is no earning source",
      "type": "checkbox",
      "required": true,
      "validation": "checked",
      "help": {
        "english": "Tick only after confirming the declaration yourself.",
        "telugu": "Declaration మీరు confirm చేసిన తర్వాత మాత్రమే tick చేయండి.",
