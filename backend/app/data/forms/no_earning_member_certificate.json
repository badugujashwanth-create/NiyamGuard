      "label": "No Earning Affidavit",
      "required": true,
      "accepted_file_types": ["pdf", "jpg", "jpeg", "png"],
      "max_size_mb": 5,
      "examples": ["Self declaration", "Affidavit"],
      "help": {
        "english": "Upload self declaration or affidavit if available.",
        "telugu": "Self declaration లేదా affidavit ఉంటే upload చేయండి.",
        "hindi": "Self declaration या affidavit हो तो upload करें."
