      }
    },
    {
      "key": "mandal",
      "label": "Mandal",
      "type": "text",
      "required": true,
      "validation": "non_empty",
      "help": {
        "english": "Enter mandal.",
        "telugu": "మండలం టైప్ చేయండి.",
        "hindi": "मंडल लिखें."
      }
    },
    {
      "key": "address",
      "label": "Address",
      "type": "textarea",
      "required": true,
      "validation": "non_empty",
      "help": {
        "english": "Enter full address.",
